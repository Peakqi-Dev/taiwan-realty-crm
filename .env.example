# =============================================================================
# Supabase (Vercel Marketplace integration)
# =============================================================================
# Provisioned automatically when you install the Supabase integration in Vercel.
# After install, run:  vercel env pull .env.local
# Both NEXT_PUBLIC_* keys are required for the app to boot (read in middleware).
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Server-only — for service-role operations (RLS bypass, admin tasks).
# Never expose to the client. NEVER prefix with NEXT_PUBLIC_.
SUPABASE_SERVICE_ROLE_KEY=

# Direct Postgres URL — used by Supabase CLI (`supabase db push`) and any
# migration tooling outside the app runtime.
POSTGRES_URL=
POSTGRES_URL_NON_POOLING=

# =============================================================================
# Planned integrations (not wired yet)
# =============================================================================
OPENAI_API_KEY=
LINE_CHANNEL_ACCESS_TOKEN=
LINE_CHANNEL_SECRET=
